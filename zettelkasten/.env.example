# Auth.js（NextAuth v5）
# 生成: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
AUTH_SECRET=

# Google OAuth
# Google Cloud Console → APIとサービス → 認証情報 → OAuth クライアントID（ウェブ）
# 承認済みリダイレクトURI:
#   ローカル: http://localhost:3000/api/auth/callback/google
#   本番:     https://<your-app>.vercel.app/api/auth/callback/google
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=

# ログインを許可するメール（カンマ区切り）。空なら誰でも可（開発用）。本番では必ず設定。
ALLOWED_EMAILS=

# Turso（本番のみ。未設定ならローカルの file:zettelkasten.db）
#   turso db show zettelkasten --url
#   turso db tokens create zettelkasten
TURSO_DATABASE_URL=
TURSO_AUTH_TOKEN=
